{
  "name": "cs-unplugged-workbook",
  "version": "1.0.0",
  "description": "Print-ready HTML/CSS template system for a children's unplugged computer science workbook",
  "main": "scripts/generate-pdf.js",
  "scripts": {
    "pdf": "node scripts/generate-pdf.js",
